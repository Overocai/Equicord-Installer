<Window x:Class="EquicordInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Equicord Installer"
        Height="660" Width="820"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanMinimize"
        FontFamily="Segoe UI"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True">

    <Window.Resources>
        <!-- Botao de destaque (blurple) -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9" Background="#5865F2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#4853E0"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#3C46C8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Background" Value="#363845"/>
                                <Setter Property="Foreground" Value="#7E8194"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botao secundario (contorno) -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Foreground" Value="#C8CBD8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" CornerRadius="9" Background="#22232C"
                                BorderBrush="#3A3D4D" BorderThickness="1">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2C2E3A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#5865F2"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#62657A"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2A2C38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Botoes da barra de titulo -->
        <Style x:Key="CaptionButton" TargetType="Button">
            <Setter Property="Foreground" Value="#B8BBCB"/>
            <Setter Property="FontFamily" Value="Segoe UI Symbol"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Width" Value="42"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="Transparent" CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#2E303C"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Barra de progresso fina e arredondada -->
        <Style x:Key="SlimBar" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Foreground" Value="#5865F2"/>
            <Setter Property="Background" Value="#22232C"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border x:Name="PART_Track" CornerRadius="4" Background="{TemplateBinding Background}"/>
                            <Border x:Name="PART_Indicator" CornerRadius="4" HorizontalAlignment="Left"
                                    Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="16" Margin="14">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.55" Color="#000000"/>
        </Border.Effect>
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#24252F" Offset="0"/>
                <GradientStop Color="#15151B" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>

        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Barra de titulo -->
            <Grid x:Name="TitleBar" Grid.Row="0" Height="46" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                    <Border Width="22" Height="22" CornerRadius="6" Background="#5865F2" VerticalAlignment="Center">
                        <TextBlock Text="E" Foreground="White" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="TitleBarName" Text="Equicord Installer" Foreground="#E6E8F0" FontWeight="SemiBold"
                               FontSize="13" Margin="10,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,8,0">
                    <Button x:Name="MinButton" Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="MinButton_Click"/>
                    <Button x:Name="CloseButton" Style="{StaticResource CaptionButton}" Content="&#xE8BB;" Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>

            <!-- Cabecalho -->
            <StackPanel Grid.Row="1" Margin="28,6,28,12">
                <TextBlock x:Name="HeaderTitle" Text="Instalar Equicord" Foreground="#F2F3F8" FontSize="26" FontWeight="Bold"/>
                <TextBlock x:Name="HeaderSubtitle" Foreground="#9396A8" FontSize="13" Margin="0,4,0,0" TextWrapping="Wrap"
                           Text="Instala tudo automaticamente: baixa Git e Node.js (se precisar), clona o Equicord em Documentos, instala as dependencias e faz o build. Nao precisa instalar nada antes."/>
            </StackPanel>

            <!-- Log -->
            <Border Grid.Row="2" Margin="28,4,28,4" CornerRadius="12" Background="#101015"
                    BorderBrush="#2A2C38" BorderThickness="1">
                <RichTextBox x:Name="LogBox"
                             Background="Transparent"
                             Foreground="#CDD0DA"
                             BorderThickness="0"
                             IsReadOnly="True"
                             IsDocumentEnabled="True"
                             FontFamily="Cascadia Mono, Consolas"
                             FontSize="12.5"
                             VerticalScrollBarVisibility="Auto"
                             Padding="6"
                             SpellCheck.IsEnabled="False"/>
            </Border>

            <!-- Progresso + status -->
            <StackPanel Grid.Row="3" Margin="28,14,28,6">
                <ProgressBar x:Name="Progress" Style="{StaticResource SlimBar}" Minimum="0" Maximum="100" Value="0"/>
                <TextBlock x:Name="StatusText" Text="Pronto." Foreground="#9396A8" FontSize="12" Margin="2,8,0,0"/>
            </StackPanel>

            <!-- Controles -->
            <Grid Grid.Row="4" Margin="28,8,28,22">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="StartButton" Grid.Column="0" Style="{StaticResource AccentButton}"
                        Content="Iniciar Instalacao" Width="210" Height="46" Click="StartButton_Click"/>

                <CheckBox x:Name="InjectCheck" Grid.Column="1" Margin="20,0,0,0"
                          VerticalAlignment="Center" IsChecked="True"
                          Foreground="#C8CBD8" FontSize="13"
                          Content="Abrir o instalador do Discord (pnpm inject) ao final"/>

                <Button x:Name="OpenFolderButton" Grid.Column="2" Style="{StaticResource GhostButton}"
                        Content="Abrir pasta" Width="120" Height="46" IsEnabled="False" Click="OpenFolderButton_Click"/>
            </Grid>
        </Grid>
    </Border>
</Window>
